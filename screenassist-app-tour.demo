# Or watch the whole season — all 22 shots


```playwright
await fx.say("The big \"Watch All\" button up top plays every shot in the season as one continuous reel.");
const watchAll = page.locator("button:has-text('Watch All')").first();
const wb = await watchAll.boundingBox().catch(() => null);
if (wb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 500),
    { x: wb.x + wb.width/2, y: wb.y + wb.height/2 });
  await page.waitForTimeout(600);
}
await watchAll.click();
await page.waitForSelector("[role='dialog'][aria-label='Clip viewer']", { timeout: 8000 });
await fx.pause(4);
await page.locator("button[aria-label='Next clip']").click();
await fx.pause(3.5);
await page.keyboard.press("Escape");
await fx.pause(0.8);
```

