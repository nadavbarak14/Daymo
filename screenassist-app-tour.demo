title: ScreenAssist — Full Product Tour
description: Logged-in walkthrough of the ScreenAssist app — every major capability, with real clicks.
url: https://screenassist.app/login
viewport: { width: 1440, height: 900 }
music: ./tour-music.mp3
---

# Sign in to ScreenAssist


```playwright
await fx.say("The pro film room every basketball player can run. Self-tag your plays, get pro-grade stats, auto-build a recruit reel.");
await page.waitForLoadState("domcontentloaded");
await page.waitForSelector("input[type='email']");
try {
  await page.locator("[role='dialog'][aria-label='Cookie consent'] button:has-text('Accept')").click({ timeout: 1500 });
} catch {}
await fx.pause(0.8);
await fx.cursorTo("input[type='email']");
await fx.typeWithDelay("input[type='email']", "eran@bstat.dev", 22);
await fx.cursorTo("input[type='password']");
await fx.typeWithDelay("input[type='password']", "test1234", 26);
await fx.pause(0.5);
await fx.cursorTo("button[type='submit']");
await fx.highlight("button[type='submit']", 1);
await fx.pause(0.8);
await page.click("button[type='submit']");
await page.waitForURL("**/overview**", { timeout: 20000 });
await page.waitForLoadState("networkidle");
await fx.pause(1.2);
```

---

# Overview — your player card


```playwright
await fx.say("Name, team, jersey, season at a glance. The first thing a recruiter sees.");
await page.evaluate(() => window.scrollTo({ top: 0, behavior: "smooth" }));
await fx.pause(1);
await page.waitForSelector("h1", { timeout: 10000 });
await fx.cursorTo("h1");
await fx.pause(2.5);
```

---

# Season splits — per-game averages


```playwright
await fx.say("Points, rebounds, assists, shooting splits — broken down by competition so league play isn't muddied by scrimmages.");
const splits = page.locator("h2:has-text('Season splits')").first();
await splits.scrollIntoViewIfNeeded();
await fx.pause(0.6);
const sb = await splits.boundingBox();
if (sb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 600),
    { x: sb.x + 60, y: sb.y + 100 });
}
await fx.pause(2.5);
await page.evaluate(() => window.scrollBy({ top: 200, behavior: "smooth" }));
await fx.pause(2);
```

---

# Recent games — every score, one click away


```playwright
await fx.say("W/L marker, opponent, score, venue. Click any row and you're in the per-game breakdown.");
const games = page.locator("h2:has-text('Recent games')").first();
await games.scrollIntoViewIfNeeded();
await fx.pause(0.6);
const firstGame = page.locator("button:has-text('vs Hod Hasharon')").first();
const gb = await firstGame.boundingBox().catch(() => null);
if (gb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 700),
    { x: gb.x + gb.width/2, y: gb.y + gb.height/2 });
}
await fx.pause(2.8);
```

---

# Top plays — every tagged moment, instantly playable


```playwright
await fx.say("Each thumbnail is a real clip. One click, the play viewer opens — no editing, no exporting.");
const topPlays = page.locator("h2:has-text('Top plays')").first();
await topPlays.scrollIntoViewIfNeeded();
await fx.pause(1);
const firstPlay = page.locator("h2:has-text('Top plays')").locator("xpath=following::button[1]");
const pb = await firstPlay.boundingBox();
if (pb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 600),
    { x: pb.x + pb.width/2, y: pb.y + pb.height/2 });
  await page.waitForTimeout(700);
}
await firstPlay.click();
await page.waitForSelector("[role='dialog'][aria-label='Clip viewer']", { timeout: 10000 });
await fx.pause(5);
```

---

# Jump between clips with one button


```playwright
await fx.say("Side arrows or keyboard — review every play in your library without a single page reload.");
const next = page.locator("button[aria-label='Next clip']").first();
const nb = await next.boundingBox();
if (nb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 500),
    { x: nb.x + nb.width/2, y: nb.y + nb.height/2 });
}
await fx.pause(0.5);
await next.click();
await fx.pause(3.5);
await next.click();
await fx.pause(3);
await page.keyboard.press("Escape");
await fx.pause(0.8);
```

