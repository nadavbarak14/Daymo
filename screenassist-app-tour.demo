# Share — your profile becomes a link


```playwright
await fx.say("The Share button opens a popover: toggle public or private, copy the link, send it.");
await page.evaluate(() => window.scrollTo({ top: 0, behavior: "smooth" }));
await fx.pause(0.6);
const shareBtn = page.locator("header button:has-text('Share')").first();
const shb = await shareBtn.boundingBox();
if (shb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 500),
    { x: shb.x + shb.width/2, y: shb.y + shb.height/2 });
  await page.waitForTimeout(600);
}
await shareBtn.click();
await page.waitForSelector("[role='dialog'][aria-label='Share profile']", { timeout: 5000 });
await fx.pause(2);
const toggle = page.locator("button[aria-label='Toggle profile visibility']").first();
const tb = await toggle.boundingBox().catch(() => null);
if (tb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 500),
    { x: tb.x + tb.width/2, y: tb.y + tb.height/2 });
}
await fx.pause(2);
const copy = page.locator("button[aria-label='Copy link']").first();
const cb = await copy.boundingBox().catch(() => null);
if (cb) {
  await page.evaluate(({x,y}) => window.__daymo.moveCursor(x, y, 500),
    { x: cb.x + cb.width/2, y: cb.y + cb.height/2 });
}
await fx.pause(2.5);
```

